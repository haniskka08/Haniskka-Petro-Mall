# Application
APP_NAME=PetroMallis
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8001

# Database
DATABASE_URL=postgresql://petromallis:petromallis_secret@localhost:5432/petromallis_db

# JWT (used from Phase 3)
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# File Storage (local; S3-ready structure in Phase 9)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp
